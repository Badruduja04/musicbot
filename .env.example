# =============================================
#  BadruMusicBot — Environment Variables
# =============================================

# Discord Bot Token (dari https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Application/Client ID
CLIENT_ID=your_application_client_id_here

# Guild ID (Server ID) untuk development — HAPUS atau KOSONGKAN untuk global deploy
# GUILD_ID=1234567890123456789

# Folder musik lokal
MUSIC_DIR=./assets

# Volume default (0-200, default: 100)
DEFAULT_VOLUME=100

# Mode debug (true/false)
DEBUG=false
